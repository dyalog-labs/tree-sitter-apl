{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "apl",
      "camelcase": "APL",
      "title": "APL",
      "scope": "source.apl",
      "file-types": [
        "apl",
        "aplf",
        "aplo",
        "apls",
        "apln",
        "dyalog"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^apl$",
      "class-name": "TreeSitterApl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "APL Tree-sitter",
    "authors": [
      {
        "name": "Jesús Galán López (yiyus)",
        "email": "jgl@dyalog.com"
      }
    ],
    "links": {
      "repository": "https://github.com/dyalog-labs/tree-sitter-apl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}