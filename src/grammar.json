                    {
                      "type": "PATTERN",
                      "value": "\\n"
                    },
                    {
                      "type": "STRING",
                      "value": "⋄"
                    },
                    {
                      "type": "STRING",
                      "value": "\u0000"
                    }
                  ]
                }
              }
            ]
          }
        },
